{
  "name": "kanji-n3-n2-trainer",
  "version": "1.0.0",
  "description": "A JLPT N3/N2 kanji learning web app designed for GitHub Pages, with functional core, imperative shell, and basic tests.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "bun tests/core.test.ts && bun tests/kanjiCache.test.ts",
    "build": "bun run build:meta && tsc",
    "build:meta": "bun scripts/updateBuildMeta.ts",
    "prepare": "bun scripts/install-hooks.ts"
  },
  "keywords": [
    "kanji",
    "JLPT",
    "N3",
    "N2",
    "Japanese",
    "TTS",
    "webapp"
  ],
